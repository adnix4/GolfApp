# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Golf Fundraiser Pro Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file to .env.local in the repo root:
#        cp .env.example .env.local
#   2. Fill in the values for your environment.
#   3. NEVER commit .env.local — it is in .gitignore.
#
# WHERE VARIABLES ARE CONSUMED:
#   • apps/api          — C# appsettings reads from environment on startup
#   • apps/admin        — Expo Router reads EXPO_PUBLIC_* at build time
#   • apps/mobile       — Expo reads EXPO_PUBLIC_* at build time
#   • apps/web          — Next.js reads NEXT_PUBLIC_* at build time; server-side reads others
#   • infra/            — docker-compose.yml reads from this file via env_file:
#
# VARIABLE NAMING CONVENTIONS (spec Foundation §9.2):
#   EXPO_PUBLIC_*   — embedded in the Expo JS bundle at build time (client-visible)
#   NEXT_PUBLIC_*   — embedded in the Next.js bundle at build time (client-visible)
#   All others      — server-side only, never exposed to the browser
#
# ─────────────────────────────────────────────────────────────────────────────
# !! SECURITY WARNING !!
# Variables marked [SERVER ONLY] must NEVER be exposed to client-side code.
# STRIPE_SECRET_KEY, JWT_SECRET, SENDGRID_API_KEY, etc. exposed client-side
# would allow anyone to charge cards, forge JWTs, or send emails as your org.
# ─────────────────────────────────────────────────────────────────────────────


# ── DATABASE ──────────────────────────────────────────────────────────────────

# DATABASE_URL — PostgreSQL connection string.
# [SERVER ONLY] — never expose this to client-side code.
#
# FORMAT:  postgresql://user:password@host:port/database?sslmode=require
# LOCAL:   no sslmode required (running in Docker without TLS)
# PROD:    sslmode=require is mandatory on Railway/Render/Supabase
#
# WHY "golf_fundraiser" (not "appdb"):
#   The spec (Foundation §8) defines the DB name as "golf_fundraiser".
#   Using a descriptive name makes it obvious which DB you're connected to
#   in pgAdmin, psql, and Railway dashboards.
#
DATABASE_URL=postgresql://gfp:gfp_local@localhost:5432/golf_fundraiser


# ── REDIS ─────────────────────────────────────────────────────────────────────

# REDIS_URL — Redis connection string.
# [SERVER ONLY] — used by the .NET API for StackExchange.Redis.
#
# FORMAT:  redis://host:port
# LOCAL:   no password (Docker Redis has no auth by default in dev)
# PROD:    use redis://:password@host:port or rediss:// for TLS
#
# USED FOR:
#   Phase 1-2: connection established, mostly idle
#   Phase 3:   leaderboard TTL cache (2-5s) + SignalR backplane
#
REDIS_URL=redis://localhost:6379


# ── AUTHENTICATION ────────────────────────────────────────────────────────────

# JWT_SECRET — signs and verifies access tokens (15-minute lifetime).
# [SERVER ONLY] — if leaked, attackers can forge valid JWTs for any user.
#
# GENERATE A STRONG VALUE:
#   openssl rand -hex 64
# (64 bytes = 512 bits of entropy — far more than the 256-bit minimum)
#
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING_openssl_rand_-hex_64

# JWT_REFRESH_SECRET — signs and verifies refresh tokens (30-day lifetime).
# [SERVER ONLY] — must be DIFFERENT from JWT_SECRET.
#
# WHY A SEPARATE SECRET:
#   If an attacker compromises the access token secret, they could generate
#   refresh tokens too (if it were the same key).  Separate secrets limit
#   blast radius: compromise of one doesn't compromise the other.
#
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING


# ── EMAIL ─────────────────────────────────────────────────────────────────────

# SENDGRID_API_KEY — used by the .NET API to send transactional emails.
# [SERVER ONLY] — if leaked, anyone can send email from your SendGrid account.
#
# FREE TIER: 100 emails/day (sufficient for Phase 1 development).
# Get a key at: https://app.sendgrid.com/settings/api_keys
#
# USED FOR (spec Phase 1 §7):
#   registration_confirm, invite, team_assignment, reminder, thank_you,
#   donation_receipt
#
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_API_KEY

# SENDGRID_FROM_EMAIL — the "From" address for all outbound emails.
# Must be a verified sender in your SendGrid account.
#
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Golf Fundraiser Pro


# ── PAYMENTS (Phase 4+) ───────────────────────────────────────────────────────

# STRIPE_SECRET_KEY — used server-side to create PaymentIntents, SetupIntents,
# and charge auction winners.
# [SERVER ONLY] — if leaked, attackers can initiate charges on your account.
#
# Use sk_test_... for development, sk_live_... for production.
# Get keys at: https://dashboard.stripe.com/apikeys
#
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# STRIPE_WEBHOOK_SECRET — used to verify that webhook events came from Stripe
# (not a malicious third party posting fake payment confirmations).
# [SERVER ONLY]
#
# Generate in Stripe Dashboard → Webhooks → Add endpoint → Signing secret.
# The endpoint to register is: https://your-api-url/webhooks/stripe
#
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# STRIPE_PUBLISHABLE_KEY — safe to expose to the browser.
# Used by the Next.js and Expo apps to initialize Stripe.js / @stripe/react-stripe-js.
#
# This IS client-safe because it can only tokenize card data (not charge cards).
#
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY


# ── MAPS (Phase 6+) ───────────────────────────────────────────────────────────

# MAPBOX_TOKEN — used by @rnmapbox/maps (mobile) and mapbox-gl-js (web).
# SAFE TO EXPOSE client-side (Mapbox tokens are scoped to specific URLs).
#
# Free tier: 50,000 map loads/month.
# Get a token at: https://account.mapbox.com/access-tokens/
#
# WHY IT'S PUBLIC:
#   Mapbox tokens are URL-restricted in the Mapbox dashboard.
#   You lock the token to your domains so it can't be used by others.
#
MAPBOX_TOKEN=pk.REPLACE_WITH_YOUR_MAPBOX_PUBLIC_TOKEN


# ── API URLs ──────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_API_URL — base URL of the .NET API, used by Next.js.
# The NEXT_PUBLIC_ prefix is required for Next.js to embed it in the browser bundle.
#
# LOCAL:    http://localhost:5000   (direct to API, bypassing nginx)
# STAGING:  https://api.staging.golffundraiser.pro
# PROD:     https://api.golffundraiser.pro
#
NEXT_PUBLIC_API_URL=http://localhost:5000

# EXPO_PUBLIC_API_URL — base URL of the .NET API, used by Expo apps.
# The EXPO_PUBLIC_ prefix is required for Expo/Metro to embed it in the JS bundle.
#
# Note: On a physical iOS/Android device during dev, "localhost" refers to
# the device itself, not your computer.  Use your computer's LAN IP instead:
#   EXPO_PUBLIC_API_URL=http://192.168.1.xxx:5000
#
EXPO_PUBLIC_API_URL=http://localhost:5000


# ── CDN / STORAGE (for logo and image uploads) ────────────────────────────────

# CDN_BASE_URL — base URL where uploaded images (org logos, sponsor logos) are served.
# [SERVER ONLY] — the upload logic reads this to construct public URLs.
#
# LOCAL:  Can use a local MinIO instance or just return relative paths during dev.
# PROD:   Set to your Cloudflare R2 / AWS S3 / Bunny CDN public URL.
#
CDN_BASE_URL=http://localhost:5000/uploads   # local dev: API serves uploads directly

# STORAGE_CONNECTION_STRING — connection string for blob storage.
# [SERVER ONLY]
# LOCAL:  leave blank to use local filesystem storage in apps/api/wwwroot/uploads/
# PROD:   set to your S3/R2/Azure Blob connection string
#
STORAGE_CONNECTION_STRING=


# ── ASPNETCORE (apps/api) ────────────────────────────────────────────────────

# ASPNETCORE_ENVIRONMENT — controls which appsettings.{env}.json is loaded.
# Valid values: Development | Staging | Production
#
ASPNETCORE_ENVIRONMENT=Development

# ASPNETCORE_URLS — the URL the Kestrel server listens on.
# Must match NEXT_PUBLIC_API_URL and EXPO_PUBLIC_API_URL for local dev.
#
ASPNETCORE_URLS=http://localhost:5000


# ── DOCKER / NGINX ────────────────────────────────────────────────────────────

# HOST_IP — used by nginx.conf to proxy to the host machine from a container.
# Mac/Windows: host.docker.internal (Docker Desktop resolves this automatically)
# Linux:       172.17.0.1  (the default Docker bridge gateway IP)
#
HOST_IP=host.docker.internal
