{
  // A3 join email verification — TEST BYPASS. Entering this value as the
  // verification code on /join skips the emailed one-time code (most dev/demo
  // player emails are fake). Development config ONLY: appsettings.json and the
  // production environment must never set it — an unset/empty value disables
  // the bypass, so production stays email-verified by default.
  "JoinVerification": {
    "TestBypassCode": "999999"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "GolfFundraiserPro": "Debug"
    }
  }
}
