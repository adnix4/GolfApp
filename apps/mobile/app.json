{
  "expo": {
    "name": "GFP Scorer",
    "slug": "gfp-scorer",
    "version": "1.0.0",
    "scheme": "gfp",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.pro.golffundraiser.scorer",
          "enableGooglePay": false
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "pro.golffundraiser.scorer",
      "supportsTablet": true
    },
    "android": {
      "package": "pro.golffundraiser.scorer",
      "predictiveBackGestureEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#31572c"
      }
    }
  }
}
