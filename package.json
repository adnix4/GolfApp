{
  "name": "golf-fundraiser-pro",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build":      "turbo run build",
    "dev":        "turbo run dev",
    "lint":       "turbo run lint",
    "type-check": "turbo run type-check",
    "test":       "turbo run test",
    "clean":      "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo":                 "^2.3.3",
    "typescript":            "^5.4.5",
    "eslint":                "^9.39.4",
    "@eslint/js":            "^9.39.4",
    "typescript-eslint":     "^8.59.1",
    "globals":               "^17.5.0",
    "prettier":              "^3.2.5",
    "vitest":                "^2.1.9",
    "@vitest/coverage-v8":   "^2.1.9"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
