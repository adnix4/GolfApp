# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Golf Fundraiser Pro Monorepo
# ─────────────────────────────────────────────────────────────────────────────
# WHY ONE ROOT .gitignore:
#   A single root file is easier to maintain than per-workspace files.
#   Patterns are relative to the location of the .gitignore file, so
#   patterns like "node_modules" match in any subdirectory.
# ─────────────────────────────────────────────────────────────────────────────

# ── NODE / NPM ──────────────────────────────────────────────────────────────
# Dependency directories — never commit, always reinstall via `npm install`
node_modules/

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files — contain secrets, never commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── TURBOREPO ────────────────────────────────────────────────────────────────
# Turborepo's local file-system cache.
# The .turbo directory holds hashed task outputs cached locally.
# Developers can share a remote cache (Vercel Remote Cache) instead.
.turbo/

# ── TYPESCRIPT ───────────────────────────────────────────────────────────────
# Compiled JavaScript output from tsc
dist/
build/

# tsc incremental build info files
*.tsbuildinfo

# ── NEXT.JS (apps/web) ───────────────────────────────────────────────────────
# Next.js production build output
.next/

# Next.js static export output
out/

# ── EXPO / REACT NATIVE (apps/mobile, apps/admin) ───────────────────────────
# Expo CLI cache and generated files
.expo/

# Expo web export
web-build/

# React Native generated native project folders.
# These are regenerated by `expo prebuild` and should NOT be committed
# unless you are managing a "bare workflow" project.
/apps/mobile/ios/
/apps/mobile/android/
/apps/admin/ios/
/apps/admin/android/

# Expo environment declaration file (auto-generated)
expo-env.d.ts

# ── .NET / C# (apps/api) ─────────────────────────────────────────────────────
# Build output directories — generated by `dotnet build` / `dotnet publish`
apps/api/bin/
apps/api/obj/

# Visual Studio / Rider user-specific files
*.user
.vs/
.vscode/launch.json
*.suo

# NuGet package restore cache — packages are restored from nuget.org on build
# Do NOT ignore: apps/api/packages.lock.json — that file pins exact versions

# ── DOCKER ───────────────────────────────────────────────────────────────────
# Docker local override file (used for developer-specific compose overrides)
docker-compose.override.yml

# ── MACOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── WINDOWS ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── EDITORS ──────────────────────────────────────────────────────────────────
# JetBrains Rider / WebStorm
.idea/

# VS Code workspace settings (keep extensions.json and settings.json in source
# control, but ignore launch configs that contain machine-specific paths)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ── TESTING ──────────────────────────────────────────────────────────────────
# Jest / Vitest coverage output
coverage/
