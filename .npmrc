# The monorepo intentionally installs with legacy peer resolution:
# react-native-web peers react@^18 vs our react@19, and SDK 56's @expo/ui
# (pulled transitively by expo-router) declares peerOptional reanimated/worklets
# whose versions conflict with expo-modules-core's worklets range. None of these
# affect the app at runtime — nothing imports reanimated/worklets — so we accept
# the peer graph rather than fight it. Making it the default here keeps `npm
# install` (Vercel) consistent with `npm ci --legacy-peer-deps` (GitHub CI) and
# local installs, instead of only working when the flag is passed by hand.
legacy-peer-deps=true
